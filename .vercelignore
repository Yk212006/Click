# Exclude large directories from Vercel deployment
node_modules/
.next/cache/
.next/trace*
.next/server/chunks/
.next/server/pages/

# Exclude documentation files
*.md
.windsurf/

# Exclude development files
.env.local
.env.local.example
.eslintrc.json
.jsconfig.json
.babelrc

# Exclude large data files
db.json

# Exclude build artifacts that aren't needed
package-lock.json

# Exclude test files
coverage/
*.test.js
*.spec.js
