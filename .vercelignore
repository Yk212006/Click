# Exclude large directories from Vercel deployment
node_modules/
.next/cache/
.next/trace*
.next/server/chunks/

# Exclude large image folders that exceed serverless limits
public/products/Solid Surface/
public/products/Flooring/
public/products/panels/
public/products/wallpaper/
public/products/gym flooring/
public/products/sports flooring/
public/products/quartz/
public/products/alabaster/
public/products/rubber flooring/
public/products/artificial grass/

# Exclude documentation files
*.md
.windsurf/

# Exclude development files
.env.local
.env.local.example
.eslintrc.json
.jsconfig.json
.babelrc

# Exclude large data files
db.json
package-lock.json

# Exclude test files
coverage/
*.test.js
*.spec.js
